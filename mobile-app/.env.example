# APK builds should use the Vercel proxy so phones can reach the backend.
EXPO_PUBLIC_API_BASE_URL=https://pulsekitchen.vercel.app/api/v1

# Local development can still override this with your laptop LAN IP.
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.25:8000/api/v1

# Production example for Netlify + Render:
# EXPO_PUBLIC_API_BASE_URL=https://your-api-gateway.onrender.com/api/v1
