{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/health", "destination": "https://roberta-scannable-deeanna.ngrok-free.dev/health" },
    { "source": "/api/v1/:path*", "destination": "https://roberta-scannable-deeanna.ngrok-free.dev/api/v1/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
