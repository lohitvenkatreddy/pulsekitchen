{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/api/v1/:path*", "destination": "/api/v1/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
