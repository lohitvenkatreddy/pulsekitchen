# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/food_delivery

# Redis
REDIS_URL=redis://redis:6379

# JWT Settings
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Brevo email OTP for customer signup
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=no-reply@your-verified-domain.com
BREVO_SENDER_NAME=PulseKitchen
SIGNUP_OTP_TTL_MINUTES=10
SIGNUP_OTP_RESEND_COOLDOWN_SECONDS=60
SIGNUP_OTP_MAX_ATTEMPTS=5

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# API Gateway upstream overrides for Render or any non-Docker deployment
AUTH_SERVICE_URL=http://auth-service:8000
USER_SERVICE_URL=http://user-service:8000
RESTAURANT_SERVICE_URL=http://restaurant-service:8000
ORDER_SERVICE_URL=http://order-service:8000
DELIVERY_SERVICE_URL=http://delivery-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
ADMIN_SERVICE_URL=http://admin-service:8000
CORS_ORIGINS=*

# Priority Weights (Order Service)
WEIGHT_URGENCY=0.4
WEIGHT_DISTANCE=0.35
WEIGHT_WAITING_TIME=0.25

# Gemini emergency document verification
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMERGENCY_VERIFICATION_MODE=auto
EMERGENCY_VERIFICATION_TOKEN_TTL_MINUTES=60

# Real-world delivery routing
# Set GOOGLE_MAPS_API_KEY for traffic-aware ETA. Without it, delivery-service
# uses OSRM road routing and falls back to straight-line ETA if routing fails.
GOOGLE_MAPS_API_KEY=
GOOGLE_DISTANCE_MATRIX_URL=https://maps.googleapis.com/maps/api/distancematrix/json
OSRM_ROUTE_URL=https://router.project-osrm.org/route/v1/driving
ROUTING_TIMEOUT_SECONDS=4
