POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=food_delivery

DATABASE_URL=postgresql://postgres:change_me_strong_password@postgres:5432/food_delivery
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=PulseKitchen
SIGNUP_OTP_TTL_MINUTES=10
SIGNUP_OTP_RESEND_COOLDOWN_SECONDS=60
SIGNUP_OTP_MAX_ATTEMPTS=5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMERGENCY_VERIFICATION_MODE=auto

GOOGLE_MAPS_API_KEY=
GOOGLE_DISTANCE_MATRIX_URL=https://maps.googleapis.com/maps/api/distancematrix/json
OSRM_ROUTE_URL=https://router.project-osrm.org/route/v1/driving
ROUTING_TIMEOUT_SECONDS=4

# This should be your Netlify site URL or custom frontend domain.
CORS_ORIGINS=https://your-site.netlify.app

AUTH_SERVICE_URL=http://auth-service:8000
USER_SERVICE_URL=http://user-service:8000
RESTAURANT_SERVICE_URL=http://restaurant-service:8000
ORDER_SERVICE_URL=http://order-service:8000
DELIVERY_SERVICE_URL=http://delivery-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
ADMIN_SERVICE_URL=http://admin-service:8000
